# Example environment variables for the Mahiru ECO Bot
# Copy this file to .env and add your own values.

DISCORD_TOKEN=YOUR_DISCORD_TOKEN_HERE
BOT_OWNER_ID=YOUR_DISCORD_USER_ID_HERE
BOT_SUPPORT_SERVER_INVITE=https://discord.gg/YOUR_INVITE_CODE
DEV_GUILD_ID=YOUR_DEV_GUILD_ID_HERE

# --- FOR THE /help COMMAND ---
VOTE_LINK=https://top.gg/bot/YOUR_BOT_ID/vote
DONATION_INFO=Support the bot at https://ko-fi.com/your-page or via PayPal: your-paypal@email.com